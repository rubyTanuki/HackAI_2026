{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Start FastAPI Backend",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/api",
            "python": "${workspaceFolder}/api/venv/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "Start React Frontend",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "cwd": "${workspaceFolder}/webapp/clerk-react",
            "console": "integratedTerminal"
        }
    ],
    "compounds": [
        {
            "name": "Run Full Stack (HackAI)",
            "configurations": [
                "Start FastAPI Backend",
                "Start React Frontend"
            ]
        }
    ]
}